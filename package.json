{
  "name": "the-stack",
  "type": "module",
  "version": "2.2.0",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:visual": "playwright test --config=playwright.visual.config.js",
    "test:visual:update": "playwright test --config=playwright.visual.config.js --update-snapshots",
    "test:visual:docker": "bash scripts/visual.sh",
    "test:visual:docker:update": "bash scripts/visual.sh --update-snapshots",
    "gen:og": "node scripts/gen-og.mjs",
    "audit": "ASTRO_TELEMETRY_DISABLED=1 npm run build && node scripts/audit.mjs && node scripts/a11y.mjs && node scripts/links.mjs"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/svelte": "^9.0.0",
    "@fontsource-variable/bricolage-grotesque": "^5.2.10",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/spline-sans": "^5.2.8",
    "astro": "^7.0.3",
    "svelte": "^5.56.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@resvg/resvg-js": "^2.6.2",
    "astro-pagefind": "^2.0.0",
    "axe-core": "^4.12.1",
    "jsdom": "^29.1.1",
    "pagefind": "^1.5.2",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
