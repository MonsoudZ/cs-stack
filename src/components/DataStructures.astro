---
const shapes = [
  ['Array', 'one address, many slots', 'Fast when you know the index; great locality because neighbors sit beside neighbors.'],
  ['Hash map', 'key → bucket → value', 'Fast lookup by turning a key into an address-like bucket, with collisions to manage.'],
  ['Tree', 'nodes linked by choices', 'Keeps data searchable or ordered by following branches instead of scanning every item.'],
];
---
<div class="widget ds-widget">
  <div class="w-label">data structures — memory with a shape</div>
  <div class="ds-grid">
    {shapes.map(([name, model, copy]) => (
      <div class="ds-card">
        <div class="ds-name">{name}</div>
        <div class="ds-model">{model}</div>
        <p>{copy}</p>
      </div>
    ))}
  </div>
  <div class="ds-memory">
    <span class="mcell active">0x10</span>
    <span class="mcell active">0x11</span>
    <span class="mcell gap">···</span>
    <span class="mcell link">0x40</span>
    <span class="mcell">0x41</span>
    <span class="mcell link">0x88</span>
  </div>
  <div class="ds-rule">The structure is not extra magic. It is a rule for how addresses point to other addresses.</div>
</div>

<style>
  .ds-widget{border-color:rgba(91,157,255,.28)}
  .ds-grid{position:relative;z-index:1;display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px}
  .ds-card{border:1px solid var(--border);border-radius:15px;padding:17px;background:rgba(8,11,18,.6)}
  .ds-name{font-family:var(--disp);font-size:24px;font-weight:800;color:var(--ink);letter-spacing:-.01em}
  .ds-model{margin-top:5px;font-family:var(--mono);font-size:11px;color:var(--blue);letter-spacing:.08em;text-transform:uppercase}
  .ds-card p{margin:12px 0 0;color:var(--dim);font-size:14px;line-height:1.6}
  .ds-memory{position:relative;z-index:1;display:flex;gap:8px;flex-wrap:wrap;margin-top:14px;font-family:var(--mono)}
  .mcell{border:1px solid var(--border);border-radius:10px;padding:10px 12px;color:var(--faint);background:rgba(255,255,255,.025)}
  .mcell.active{border-color:var(--blue);color:var(--blue);background:var(--blue-d)}
  .mcell.link{border-color:var(--signal);color:var(--signal);background:var(--signal-d)}
  .mcell.gap{opacity:.5}
  .ds-rule{position:relative;z-index:1;margin-top:12px;border:1px solid rgba(91,157,255,.28);border-radius:13px;padding:13px 15px;
    background:var(--blue-d);color:var(--dim);font-size:14px;line-height:1.6}
  @media(max-width:760px){.ds-grid{grid-template-columns:1fr}}
</style>
