---
const boundaries = [
  ['Process boundary', 'The OS keeps programs in separate address spaces so one app cannot casually read another app.'],
  ['Permission boundary', 'Files, devices, cameras, sockets, and secrets require explicit authority instead of ambient access.'],
  ['Trust boundary', 'When data crosses a network or user input enters the system, the program must verify before believing.'],
  ['Crypto boundary', 'Encryption and signatures protect bytes when the path between machines cannot be trusted.'],
];
---
<div class="widget security-widget">
  <div class="w-label">security — every layer needs a boundary</div>
  <div class="security-shell">
    <div class="secure-core">
      <div class="lock">◇</div>
      <div>
        <div class="core-title">trusted core</div>
        <p>Small, checked, permissioned work should happen inside the boundary.</p>
      </div>
    </div>
    <div class="boundary-rings">
      {boundaries.map(([name, copy]) => (
        <div class="boundary">
          <span>{name}</span>
          <p>{copy}</p>
        </div>
      ))}
    </div>
  </div>
</div>

<style>
  .security-widget{border-color:rgba(255,180,84,.32)}
  .security-shell{position:relative;z-index:1;display:grid;grid-template-columns:minmax(220px,.34fr) minmax(0,1fr);gap:14px;align-items:stretch}
  .secure-core{border:1px solid rgba(255,180,84,.38);border-radius:16px;padding:18px;background:var(--amber-d);
    display:flex;gap:14px;align-items:center}
  .lock{width:48px;height:48px;border-radius:50%;display:flex;align-items:center;justify-content:center;
    border:1px solid var(--amber);color:var(--amber);box-shadow:0 0 22px var(--amber-d);font-size:28px}
  .core-title{font-family:var(--disp);font-size:25px;font-weight:800;color:var(--ink);letter-spacing:-.01em}
  .secure-core p{margin:7px 0 0;color:var(--dim);font-size:14px;line-height:1.55}
  .boundary-rings{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px}
  .boundary{border:1px solid var(--border);border-radius:14px;padding:15px;background:rgba(8,11,18,.62)}
  .boundary span{font-family:var(--mono);font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--amber)}
  .boundary p{margin:8px 0 0;color:var(--dim);font-size:14px;line-height:1.58}
  @media(max-width:820px){.security-shell{grid-template-columns:1fr}}
  @media(max-width:560px){.boundary-rings{grid-template-columns:1fr}}
</style>
