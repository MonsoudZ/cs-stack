---
const { problem, idea, tradeoff, next } = Astro.props;
const rows = [
  ['Problem', problem],
  ['Idea', idea],
  ['Tradeoff', tradeoff],
  ['Next', next],
].filter(([, value]) => value);
---
<details class="why">
  <summary>Why this exists</summary>
  <div class="why-grid">
    {rows.map(([label, value]) => (
      <div class="why-item">
        <div class="why-k">{label}</div>
        <div class="why-v">{value}</div>
      </div>
    ))}
  </div>
</details>

<style>
  .why{margin-top:18px;border:1px solid var(--border);border-radius:14px;background:rgba(17,29,46,.45);overflow:hidden}
  .why summary{font-family:var(--mono);font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--accent,var(--signal));
    cursor:pointer;list-style:none;padding:13px 16px;display:flex;align-items:center;justify-content:space-between;gap:14px}
  .why summary::-webkit-details-marker{display:none}
  .why summary::after{content:"+";font-size:16px;color:var(--faint);transition:.16s}
  .why[open] summary{border-bottom:1px solid var(--border);background:rgba(255,255,255,.02)}
  .why[open] summary::after{content:"–";color:var(--accent,var(--signal))}
  .why summary:hover{background:rgba(255,255,255,.025)}
  .why-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:1px;background:var(--border)}
  .why-item{background:rgba(8,11,18,.72);padding:15px 16px}
  .why-k{font-family:var(--mono);font-size:10px;letter-spacing:.13em;text-transform:uppercase;color:var(--faint);margin-bottom:7px}
  .why-v{color:var(--dim);line-height:1.6;font-size:14px}
  @media(max-width:680px){.why-grid{grid-template-columns:1fr}}
</style>
