---
// Self-hosted fonts (no render-blocking third-party request to Google Fonts,
// no privacy leak). Weights match what the design system actually uses.
import '@fontsource-variable/bricolage-grotesque'; // display — optical-size + weight axes
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
import '@fontsource/jetbrains-mono/700.css';
import '@fontsource/spline-sans/400.css';
import '@fontsource/spline-sans/500.css';
import '../styles/global.css';
const {
  title = 'THE STACK — electrons to the cloud',
  description = 'An explorable explanation of the computing stack, from silicon to the cloud. Climb 13 layers — transistors, gates, bits, the CPU, the OS, the network — and trace a real algorithm all the way down.',
} = Astro.props;
const base = Astro.site ?? Astro.url;
const canonical = new URL(Astro.url.pathname, base);
const ogImage = new URL('/og.png', base);
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="theme-color" content="#070a10" />
  <link rel="canonical" href={canonical} />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

  <!-- Open Graph / Twitter cards for link previews -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
</head>
<body>
  <div class="bg-grid"></div>
  <div class="bg-glow"></div>
  <div class="scan"></div>

  <header class="hero">
    <div class="kicker">A field guide to the machine</div>
    <h1 class="title">FROM <em>ELECTRONS</em><br />TO THE CLOUD</h1>
    <p class="lede">Every layer of computing is a <b>convenient lie</b> told by the layer beneath it. Climb the ladder and watch each lie get built — by hand, where you can poke it.</p>
    <div class="hero-meta"><span>13 layers + a live tracer</span> · silicon → voltage → gates → bits → numbers → meaning → CPU → OS → network → cloud</div>
    <div class="scrollcue">↓ start at the bottom</div>
  </header>

  <div class="stage">
    <nav class="spine" aria-label="Layer navigation">
      <div class="spine-track" id="spineTrack">
        <div class="spine-line"></div>
        <div class="spine-fill" id="spineFill"></div>
        <div class="spine-pulse" id="spinePulse"></div>
      </div>
    </nav>
    <main id="main">
      <slot />
    </main>
  </div>

  <footer>
    <div><span class="updot">●</span> <b>THE STACK</b> — Astro + Svelte islands + MDX. Static prose ships zero JS; each widget is a hydrated island.</div>
    <div style="margin-top:8px">Run <code>npm run dev</code> to develop, <code>npm run build</code> for a static bundle.</div>
  </footer>

  <script>
    const $ = (s, el = document) => el.querySelector(s);
    const $$ = (s, el = document) => [...el.querySelectorAll(s)];
    const mk = (t, c, h) => { const e = document.createElement(t); if (c) e.className = c; if (h != null) e.innerHTML = h; return e; };
    const LAYERS = [
      ['−01','Silicon','Lsi'],
      ['00','Voltage','L0'],['01','Transistor','L1'],['02','Logic gates','L2'],['03','Bits → numbers','L3'],
      ['04','Arithmetic','L4'],['05','Numbers → things','L5'],['06','The CPU','L6'],['07','Memory','L7'],
      ['08','OS','L8'],['09','Network','L9'],['10','Cloud','L10'],['11','The whole thing','L11'],['★','Trace','L12']
    ];
    const track = $('#spineTrack');
    LAYERS.forEach(([n, lbl, id]) => {
      const b = mk('button', 'rung');
      b.innerHTML = `<span class="num">${n}</span><span class="lbl">${lbl}</span>`;
      b.onclick = () => {
        const el = document.getElementById(id); if (!el) return;
        const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        el.scrollIntoView({ behavior: reduce ? 'auto' : 'smooth', block: 'start' });
      };
      track.appendChild(b);
    });
    const rungs = $$('.rung');
    const fill = $('#spineFill'), pulse = $('#spinePulse');
    const sections = LAYERS.map((a) => document.getElementById(a[2])).filter(Boolean);
    let activeId = null;
    // Don't write the hash until the user actually scrolls — otherwise the
    // first onScroll() would clobber an inbound deep-link anchor (e.g. #L12)
    // before the browser gets to scroll there.
    let userScrolled = false;
    function onScroll() {
      const stage = $('.stage'); if (!stage) return;
      const r = stage.getBoundingClientRect();
      const total = stage.offsetHeight - window.innerHeight;
      const p = Math.min(1, Math.max(0, (-r.top) / Math.max(1, total)));
      const trackH = $('.spine-line').offsetHeight;
      fill.style.height = (p * trackH) + 'px';
      pulse.style.top = (p * trackH) + 'px';
      let best = 0, bestD = 1e9;
      sections.forEach((s, i) => { const d = Math.abs(s.getBoundingClientRect().top - 90); if (d < bestD) { bestD = d; best = i; } });
      rungs.forEach((rg, i) => { const on = i === best; rg.classList.toggle('on', on); rg.setAttribute('aria-current', on ? 'true' : 'false'); });
      // Reflect the layer you're reading in the URL so it's deep-linkable/shareable.
      const id = sections[best] && sections[best].id;
      if (id && id !== activeId) {
        activeId = id;
        if (userScrolled) history.replaceState(null, '', location.pathname + location.search + '#' + id);
      }
    }
    // rAF-throttle: scroll fires far more often than we need to read layout.
    let ticking = false;
    const onScrollRaf = () => { userScrolled = true; if (!ticking) { ticking = true; requestAnimationFrame(() => { ticking = false; onScroll(); }); } };
    window.addEventListener('scroll', onScrollRaf, { passive: true });
    window.addEventListener('resize', onScrollRaf);
    onScroll();
  </script>
</body>
</html>
