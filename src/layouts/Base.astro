---
// Self-hosted fonts (no render-blocking third-party request to Google Fonts,
// no privacy leak). Latin-only subsets — the site is English, so the
// cyrillic/greek/vietnamese/latin-ext subsets and the legacy .woff fallbacks
// (the subset CSS is woff2-only) are never needed. Only the weight axis of the
// variable display font is used (no optical-size/width in the CSS).
import '@fontsource-variable/bricolage-grotesque/wght.css'; // display — weight axis
import '@fontsource/jetbrains-mono/latin-400.css';
import '@fontsource/jetbrains-mono/latin-500.css';
import '@fontsource/jetbrains-mono/latin-700.css';
import '@fontsource/spline-sans/latin-400.css';
import '@fontsource/spline-sans/latin-500.css';
import '../styles/global.css';
// Preload the above-the-fold faces (hero display + body) so they aren't
// discovered only after the stylesheet parses — avoids the hero FOUT/swap.
import bricolageHero from '@fontsource-variable/bricolage-grotesque/files/bricolage-grotesque-latin-wght-normal.woff2?url';
import splineBody from '@fontsource/spline-sans/files/spline-sans-latin-400-normal.woff2?url';
// The layers that drive the spine nav + structured data. Defaults to the main
// stack, but any page can pass its own set (e.g. /network) so the same engine
// powers sibling explorables. The page's sections render from the same array,
// so the nav and content can't drift.
import { layers as mainLayers } from '../data/layers.js';
import StackNav from '../components/StackNav.astro';
import { stacks } from '../data/stacks.js';
// The current page's slug (''/home for the main stack), used to tell the
// cross-stack footer which deep-dive to omit from its list.
const currentSlug = Astro.url.pathname.replace(/\//g, '');
const {
  title = 'THE STACK — electrons to the cloud',
  description = 'An explorable explanation of the computing stack, from silicon to the cloud. Climb the layers — transistors, gates, bits, the CPU, memory, the OS, the network — and trace a real algorithm all the way down.',
  layers = mainLayers,
  // Utility pages (e.g. 404) set chrome={false} to drop the layer-spine nav,
  // reader guide, guided-tour CTA, and keyboard hint — there are no sections.
  chrome = true,
} = Astro.props;
const base = Astro.site ?? Astro.url;
const canonical = new URL(Astro.url.pathname, base);
// Per-stack social card when on a deep dive (committed at public/og/<slug>.png),
// otherwise the site card. Alt text tracks the same source so previews and
// screen readers stay in sync.
const currentStack = stacks.find((s) => s.slug === currentSlug);
const ogImage = new URL(currentStack ? `/og/${currentStack.slug}.png` : '/og.png', base);
const ogImageAlt = currentStack
  ? `THE ${currentStack.name.toUpperCase()} ${currentStack.kind.toUpperCase()} — a deep dive into layer ${currentStack.layer}`
  : 'THE STACK — from electrons to the cloud';
// Structured data (schema.org). URLs derive from `canonical`, so they update
// automatically once `site` is set. The topic list reuses the layer data so
// it can't drift from the page; the two meta-layers (recap, tracer) are left
// out as they aren't standalone subjects.
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${canonical}#website`,
      url: canonical.href,
      name: 'THE STACK',
      description,
      inLanguage: 'en',
    },
    {
      '@type': ['TechArticle', 'LearningResource'],
      '@id': `${canonical}#article`,
      isPartOf: { '@id': `${canonical}#website` },
      mainEntityOfPage: canonical.href,
      headline: title,
      description,
      inLanguage: 'en',
      image: ogImage.href,
      learningResourceType: 'explorable explanation',
      educationalLevel: 'beginner',
      about: layers
        .filter((l) => !['L11', 'L12'].includes(l.id))
        .map((l) => ({ '@type': 'Thing', name: l.navLabel })),
    },
  ],
};
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <!-- Set the theme before first paint (no flash): saved choice, else OS preference. -->
  <script is:inline>
    (() => {
      try {
        const saved = localStorage.getItem('theme');
        document.documentElement.dataset.theme =
          saved || (matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
      } catch (e) { document.documentElement.dataset.theme = 'dark'; }
    })();
  </script>
  <link rel="preload" href={bricolageHero} as="font" type="font/woff2" crossorigin="anonymous" />
  <link rel="preload" href={splineBody} as="font" type="font/woff2" crossorigin="anonymous" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="theme-color" content="#070a10" />
  <link rel="canonical" href={canonical} />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

  <!-- Open Graph / Twitter cards for link previews -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="THE STACK" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content={ogImageAlt} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <meta name="twitter:image:alt" content={ogImageAlt} />

  <!-- schema.org structured data for search engines -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</head>
<body>
  <a href="#main" class="skip-link">Skip to content</a>
  <button type="button" id="themeToggle" class="theme-toggle" aria-label="Switch color theme" hidden></button>
  <div class="bg-grid"></div>
  <div class="bg-glow"></div>
  <div class="scan"></div>

  <header class="hero">
    <slot name="hero">
      <div class="kicker">A field guide to the machine</div>
      <h1 class="title">FROM <em>ELECTRONS</em><br />TO THE CLOUD</h1>
      <p class="lede">Every layer of computing is a <b>convenient lie</b> told by the layer beneath it. Climb the ladder and watch each lie get built — by hand, where you can poke it.</p>
      <div class="hero-meta">silicon → voltage → gates → bits → runtime → CPU → cache → memory → data structures → OS → security → network → cloud → database → UI</div>
      <p class="hero-cta"><a class="hero-path" href="/learn">▶ Follow the guided path</a> <a class="hero-search" href="/search">⌕ Search</a></p>
    </slot>
    {chrome && (
      <Fragment>
        <ol class="reader-guide" aria-label="How to read this site">
          <li><b>1</b> poke the diagram</li>
          <li><b>2</b> read the takeaway</li>
          <li><b>3</b> open why</li>
        </ol>
        <!-- Enhancement only: revealed by the script, since the tour needs JS. -->
        <button type="button" id="tourStart" class="tour-start" aria-expanded="false" hidden>▶ Play the climb</button>
        <p class="kbd-hint">Tip: press <kbd>j</kbd> / <kbd>k</kbd> to jump between layers.</p>
      </Fragment>
    )}
  </header>

  {chrome && (
    <noscript>
      <p class="noscript-note">This page reads fine without JavaScript — all the prose, takeaways, and the
      voltage and transistor toggles work. The step-through diagrams (the CPU, call stack, scheduler,
      network, cloud, and the tracer) need JavaScript to animate; enable it to poke them.</p>
    </noscript>
  )}

  <div class:list={['stage', { 'stage--bare': !chrome }]}>
    {chrome && (
      <nav class="spine" aria-label="Layer navigation">
        <div class="spine-track" id="spineTrack">
          <div class="spine-line"></div>
          <div class="spine-fill" id="spineFill"></div>
          <div class="spine-pulse" id="spinePulse"></div>
          {layers.map(({ num, navLabel, id }) => (
            <a class="rung" href={`#${id}`}><span class="num">{num}</span><span class="lbl">{navLabel}</span></a>
          ))}
        </div>
      </nav>
    )}
    <main id="main" tabindex="-1" aria-keyshortcuts="j k" data-pagefind-body>
      <slot />
      <StackNav current={currentSlug} />
    </main>
  </div>

  <div class="tourbar" id="tourbar" role="region" aria-label="Guided tour" hidden>
    <div class="tour-status" id="tourStatus" aria-live="polite"></div>
    <div class="tour-controls">
      <button type="button" id="tourPrev" class="tour-btn" aria-label="Previous layer">◀</button>
      <button type="button" id="tourToggle" class="tour-btn" aria-label="Pause tour">⏸ Pause</button>
      <button type="button" id="tourNext" class="tour-btn" aria-label="Next layer">▶</button>
      <button type="button" id="tourStop" class="tour-btn tour-stop" aria-label="Stop tour">Stop</button>
    </div>
  </div>

  <script>
    const $ = (s, el = document) => el.querySelector(s);
    const $$ = (s, el = document) => [...el.querySelectorAll(s)];
    // Progressive enhancement: the rungs are already in the DOM as <a href="#…">
    // (so navigation works with no JS). Here we only upgrade them — smooth
    // scroll, scroll-spy highlighting, and the animated progress fill.
    const rungs = $$('.rung');
    const fill = $('#spineFill'), pulse = $('#spinePulse');
    const sections = rungs.map((rg) => document.getElementById((rg.getAttribute('href') || '').slice(1)));
    let activeId = null, activeBest = 0;
    // Don't write the hash until the user actually scrolls — otherwise the
    // first onScroll() would clobber an inbound deep-link anchor (e.g. #L12)
    // before the browser gets to scroll there.
    let userScrolled = false;
    const reduceMotion = () => window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    rungs.forEach((rg, i) => {
      rg.addEventListener('click', (e) => {
        const el = sections[i]; if (!el) return; // missing target → let the browser handle it
        e.preventDefault();
        el.scrollIntoView({ behavior: reduceMotion() ? 'auto' : 'smooth', block: 'start' });
        userScrolled = true;
        history.replaceState(null, '', location.pathname + location.search + '#' + el.id);
      });
    });
    // Keyboard layer nav: j / k jump to the next / previous layer.
    function jumpLayer(delta) {
      const el = sections[Math.max(0, Math.min(activeBest + delta, sections.length - 1))];
      if (!el) return;
      userScrolled = true;
      el.scrollIntoView({ behavior: reduceMotion() ? 'auto' : 'smooth', block: 'start' });
    }
    document.addEventListener('keydown', (e) => {
      if (e.metaKey || e.ctrlKey || e.altKey) return;
      const t = e.target, tag = t && t.tagName;
      if (tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT' || (t && t.isContentEditable)) return;
      if (e.key === 'j') { e.preventDefault(); jumpLayer(1); }
      else if (e.key === 'k') { e.preventDefault(); jumpLayer(-1); }
    });

    // Expand every Why panel for printing, then restore on the way out.
    let printOpened = [];
    window.addEventListener('beforeprint', () => {
      printOpened = $$('details:not([open])');
      printOpened.forEach((d) => { d.open = true; });
    });
    window.addEventListener('afterprint', () => {
      printOpened.forEach((d) => { d.open = false; });
      printOpened = [];
    });

    // Theme toggle (initial theme is set by the inline head script, no flash).
    const themeToggle = $('#themeToggle'), root = document.documentElement;
    if (themeToggle) {
      const sync = () => {
        const dark = root.dataset.theme !== 'light';
        themeToggle.textContent = dark ? '☀' : '☾';
        themeToggle.setAttribute('aria-label', dark ? 'Switch to light theme' : 'Switch to dark theme');
        themeToggle.setAttribute('aria-pressed', String(!dark));
      };
      themeToggle.addEventListener('click', () => {
        root.dataset.theme = root.dataset.theme === 'light' ? 'dark' : 'light';
        try { localStorage.setItem('theme', root.dataset.theme); } catch (e) {}
        sync();
      });
      sync();
      themeToggle.hidden = false;
    }
    function onScroll() {
      const stage = $('.stage'); if (!stage) return;
      const r = stage.getBoundingClientRect();
      const total = stage.offsetHeight - window.innerHeight;
      const p = Math.min(1, Math.max(0, (-r.top) / Math.max(1, total)));
      const line = $('.spine-line');
      if (line && fill && pulse) {
        const trackH = line.offsetHeight;
        fill.style.height = (p * trackH) + 'px';
        pulse.style.top = (line.offsetTop + p * trackH) + 'px';
      }
      let best = 0, bestD = 1e9;
      sections.forEach((s, i) => { if (!s) return; const d = Math.abs(s.getBoundingClientRect().top - 90); if (d < bestD) { bestD = d; best = i; } });
      activeBest = best;
      rungs.forEach((rg, i) => { const on = i === best; rg.classList.toggle('on', on); rg.setAttribute('aria-current', on ? 'true' : 'false'); });
      // Reflect the layer you're reading in the URL so it's deep-linkable/shareable.
      const id = sections[best] && sections[best].id;
      if (id && id !== activeId) {
        activeId = id;
        if (userScrolled) history.replaceState(null, '', location.pathname + location.search + '#' + id);
      }
    }
    // rAF-throttle: scroll fires far more often than we need to read layout.
    let ticking = false;
    const onScrollRaf = () => { userScrolled = true; if (!ticking) { ticking = true; requestAnimationFrame(() => { ticking = false; onScroll(); }); } };
    window.addEventListener('scroll', onScrollRaf, { passive: true });
    window.addEventListener('resize', onScrollRaf);
    onScroll();

    // ---- guided tour: auto-climb the stack, bottom to top ----
    // Drives the same sections the nav uses, so the spine fill animates along.
    const STEP_MS = 6500;
    const tourStartBtn = $('#tourStart'), tourbar = $('#tourbar');
    const tourStatus = $('#tourStatus'), tourToggle = $('#tourToggle');
    if (tourStartBtn && tourbar && sections.length) {
      let tourIdx = 0, tourTimer = null, paused = false;
      const labelAt = (i) => {
        const r = rungs[i];
        const num = r?.querySelector('.num')?.textContent?.trim() || '';
        const lbl = r?.querySelector('.lbl')?.textContent?.trim() || '';
        return `Climbing ${num} ${lbl} · ${i + 1} of ${sections.length}`;
      };
      const goTo = (i) => {
        tourIdx = Math.max(0, Math.min(i, sections.length - 1));
        const el = sections[tourIdx];
        if (el) el.scrollIntoView({ behavior: reduceMotion() ? 'auto' : 'smooth', block: 'start' });
        tourStatus.textContent = labelAt(tourIdx);
      };
      const clear = () => { if (tourTimer) { clearTimeout(tourTimer); tourTimer = null; } };
      const schedule = () => {
        clear();
        if (paused) return;
        tourTimer = setTimeout(() => {
          if (tourIdx >= sections.length - 1) stopTour();
          else { goTo(tourIdx + 1); schedule(); }
        }, STEP_MS);
      };
      const setToggle = () => {
        tourToggle.textContent = paused ? '▶ Resume' : '⏸ Pause';
        tourToggle.setAttribute('aria-label', paused ? 'Resume tour' : 'Pause tour');
      };
      const onTourKey = (e) => { if (e.key === 'Escape') stopTour(); };
      function startTour() {
        paused = false; tourbar.hidden = false;
        tourStartBtn.setAttribute('aria-expanded', 'true');
        document.addEventListener('keydown', onTourKey);
        setToggle(); goTo(0); schedule();
      }
      function stopTour() {
        clear(); tourbar.hidden = true;
        tourStartBtn.setAttribute('aria-expanded', 'false');
        document.removeEventListener('keydown', onTourKey);
        tourStartBtn.focus();
      }
      tourStartBtn.addEventListener('click', startTour);
      $('#tourStop').addEventListener('click', stopTour);
      tourToggle.addEventListener('click', () => { paused = !paused; setToggle(); schedule(); });
      $('#tourNext').addEventListener('click', () => { goTo(tourIdx + 1); schedule(); });
      $('#tourPrev').addEventListener('click', () => { goTo(tourIdx - 1); schedule(); });
      tourStartBtn.hidden = false; // reveal now that the tour is wired
    }
  </script>
</body>
</html>
